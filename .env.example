# ===== AI 接口配置 =====
# 选择 AI provider: openai | deepseek | qwen | custom | minimax
# 推荐 minimax (国内直连, 中文优秀, 兼容 OpenAI 协议)
AI_PROVIDER=minimax

# API Key (必填)
# minimax 申请: https://api.minimaxi.com
AI_API_KEY=sk-cp-your-key-here

# Base URL (根据 provider 自动填充, 也可自定义)
# OpenAI:    https://api.openai.com/v1
# DeepSeek:  https://api.deepseek.com/v1
# Qwen:      https://dashscope.aliyuncs.com/compatible-mode/v1
# minimax:   https://api.minimaxi.com/v1
AI_BASE_URL=https://api.minimaxi.com/v1

# 模型名称
# OpenAI:    gpt-4o-mini / gpt-4o
# DeepSeek:  deepseek-chat
# Qwen:      qwen-plus / qwen-turbo
# minimax:   MiniMax-M3 (thinking) / MiniMax-M2.5-highspeed (fast)
AI_MODEL=MiniMax-M3

# ===== 行为参数 =====
AI_TIMEOUT=60
AI_MAX_RETRIES=3
# AI 反思循环 (self_eval 低分时自动重生成)
AI_REFLECTION_MAX_ROUNDS=2
AI_REFLECTION_THRESHOLD=0.7

# ===== 报告日期 (留空默认"今天", 格式 YYYY-MM-DD) =====
REPORT_DATE=

# ===== 爬虫配置 =====
# 默认只启用 人民网 + 中国经济网
ENABLE_PEOPLE=1
ENABLE_CE=1
ENABLE_XINHUA=0
ENABLE_21CBH=0
ENABLE_GOV_PBOC=0
